# Environment Variables Example
# Copy this file to .env and fill in your values

# Firebase Configuration
FIREBASE_API_KEY=AIzaSyDemoKeyPlaceholder123456789
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# EmailJS Configuration
EMAILJS_SERVICE_ID=service_xxxxx
EMAILJS_PUBLIC_KEY=your_public_key_xxxxx
EMAILJS_TEMPLATE_ID=template_xxxxx
EMAILJS_FROM_EMAIL=noreply@example.com

# Application Settings
ENVIRONMENT=development
APP_URL=http://localhost:5000
APP_NAME=Certificate Generator
MAX_FILE_SIZE=5242880

# Admin Settings
ADMIN_EMAIL=admin@example.com
ENABLE_REGISTRATION=true
ENABLE_BULK_UPLOAD=true
ENABLE_EMAIL_NOTIFICATIONS=true

# Security
ENCRYPTION_KEY=your_encryption_key_here
SESSION_TIMEOUT=3600

# Analytics
ENABLE_ANALYTICS=true
GA_TRACKING_ID=

# Database
FIRESTORE_READ_LIMIT=100000
FIRESTORE_WRITE_LIMIT=50000
